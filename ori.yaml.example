# ori.yaml.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ori.yaml and edit for your device.
# ori.yaml is gitignored — never commit it.
#
# ACTION TIER REFERENCE:
#   Tier A  INFORMATIONAL   — Always autonomous. Alerts, logs, reports.
#   Tier B  SOFT PHYSICAL   — Autonomous by default. Power switching, valves.
#   Tier C  HARD PHYSICAL   — Approval workflow required. Breakers, shutdowns.
#   Tier D  SAFETY-CRITICAL — Always autonomous. Cannot be overridden.
# ─────────────────────────────────────────────────────────────────────────────

device:
  id: energy-monitor-ikeja-01        # unique, no spaces, no special chars
  name: Ikeja Office Energy Monitor
  location: Lagos, Nigeria
  country_code: NG                  # ISO 3166-1 alpha-2 (e.g. NG, KE, US)
  deployment_type: pi                # pi | phone | server
  rated_capacity_amps: 10.0          # used for Tier D threshold calculations
                                     # set this to the actual rated amperage
                                     # of your main circuit
  timezone: Africa/Lagos             # IANA timezone for Tier C approval messages
                                     # operators see local time, not UTC
                                     # e.g. Africa/Lagos, Europe/London, America/New_York

sensors:
  # ─── Current clamp on ADS1115 ADC via I2C ───────────────────────────────
  # SCT-013-030 clips around the main load cable in the distribution board
  # Non-invasive — no wiring changes required
  - id: load-current
    type: ads1115_current
    protocol: i2c
    address: 0x48                    # ADS1115 default I2C address
    channel: 0                       # ADS1115 channel A0
    poll_interval_ms: 1000
    calibration:
      sensitivity: 0.1              # SCT-013-030: 1A per 10mV output

  # ─── Grid voltage sensor on ADS1115 channel 1 ───────────────────────────
  - id: grid-voltage
    type: ads1115_voltage
    protocol: i2c
    address: 0x48
    channel: 1
    poll_interval_ms: 2000

  # ─── Serial Modbus meter (optional) ──────────────────────────────────────
  # Example for PZEM/SDM-style RS485 meters over USB serial
  - id: grid-active-power
    type: active_power
    protocol: serial
    port: /dev/ttyUSB0
    baud_rate: 9600
    poll_interval_ms: 5000

  # ─── Growatt/Deye inverter via SolarmanV5 (optional) ─────────────────────
  # Uncomment for installations with a Growatt or Deye WiFi/LAN dongle
  # - id: inverter-solar-power
  #   type: growatt_pv_power
  #   protocol: growatt
  #   host: "192.168.1.XXX"
  #   serial: "XXXXXXXXXX"
  #   port: 8899
  #   poll_interval_ms: 5000

  # ─── Victron inverter via VenusOS MQTT (optional) ──────────────────────────
  # - id: victron-battery
  #   type: victron_battery_soc
  #   protocol: victron
  #   broker_host: "192.168.1.50"
  #   portal_id: "YOUR_PORTAL_ID"
  #   port: 1883
  #   # Optional broker auth/TLS (works with Mosquitto and other MQTT brokers)
  #   mqtt:
  #     username: "mqtt-user"
  #     password: "${MQTT_PASSWORD}"
  #     client_id: "ori-victron-01"
  #     keepalive: 90
  #     tls:
  #       enabled: false
  #       insecure: false
  #       # ca_certfile: "/etc/ssl/certs/ca-certificates.crt"
  #       # certfile: "/path/to/client.crt"
  #       # keyfile: "/path/to/client.key"
  #   poll_interval_ms: 5000

  # ─── OPC-UA industrial PLC sensor (optional) ───────────────────────────────
  # - id: plc-temperature
  #   type: temperature
  #   protocol: opcua
  #   url: "opc.tcp://192.168.1.100:4840"
  #   node_id: "ns=2;i=1002"
  #   poll_interval_ms: 1000

  # ─── PC/Mac system health (PC-Ori) ──────────────────────────────────────
  # Uncomment to monitor the host machine — no hardware required
  # - id: system-cpu
  #   type: cpu_percent
  #   protocol: psutil
  #   poll_interval_ms: 5000
  #
  # - id: system-memory
  #   type: memory_percent
  #   protocol: psutil
  #   poll_interval_ms: 10000
  #
  # - id: system-temp
  #   type: cpu_temp
  #   protocol: psutil
  #   poll_interval_ms: 10000

  # ─── Phone Gateway USB meter (Termux path) ───────────────────────────────
  # - id: mains-power
  #   type: usb_power
  #   protocol: usb_serial
  #   device_path: /dev/ttyUSB0
  #   baud_rate: 9600
  #   poll_interval_ms: 2000

  # ─── Drive SMART health (PC-Ori extension) ────────────────────────────────
  # - id: drive-temp
  #   type: drive_temp_celsius
  #   protocol: smart
  #   device: /dev/sda
  #   poll_interval_ms: 60000

  # ─── Virtual sensor: weather API (optional) ───────────────────────────────
  # - id: outdoor-temperature
  #   type: temperature
  #   protocol: http
  #   url: "http://api.openweathermap.org/data/2.5/weather?q=Lagos&appid=YOUR_KEY"
  #   json_path: "main.temp"
  #   unit: kelvin
  #   poll_interval_ms: 300000

  # ─── CoAP telemetry sensor (optional) ──────────────────────────────────────
  # Requires the host to be listed under actions.coap.allowed_hosts.
  # - id: room-temp-coap
  #   type: temperature
  #   protocol: coap
  #   uri: "coap://192.168.1.70/telemetry/temp"
  #   method: GET
  #   json_path: "metrics.temp_c"
  #   unit: celsius
  #   poll_interval_ms: 2000

  # ─── Zigbee smart-home sensor via MQTT bridge (optional) ──────────────────
  # Requires zigbee2mqtt (or equivalent) publishing JSON payloads.
  # - id: living-room-temp
  #   type: temperature
  #   protocol: zigbee
  #   broker_host: "192.168.1.55"
  #   topic: "zigbee2mqtt/living-room"
  #   port: 1883
  #   # value_path defaults from sensor type mapping; override if needed:
  #   # value_path: "temperature"
  #   # quality_path: "quality"
  #   poll_interval_ms: 2000

  # ─── LoRaWAN uplink sensor via MQTT broker (optional) ─────────────────────
  # Works with TTN/ChirpStack MQTT uplink events using configurable JSON paths.
  # - id: field-temperature
  #   type: lorawan_temperature
  #   protocol: lorawan
  #   broker_host: "192.168.1.88"
  #   topic: "v3/app@ttn/devices/device-01/up"
  #   port: 1883
  #   # value_path defaults from sensor type mapping; override for your payload:
  #   # value_path: "uplink_message.decoded_payload.temperature"
  #   poll_interval_ms: 5000

  # ─── Generic MQTT telemetry sensor (optional) ─────────────────────────────
  # Use this when a device publishes JSON measurements to a broker.
  # - id: chiller-supply-temp
  #   type: temperature
  #   protocol: mqtt
  #   broker_host: "192.168.1.20"
  #   topic: "plant/chiller-1/supply"
  #   value_path: "reading.value"
  #   quality_path: "reading.quality"
  #   unit: celsius
  #   poll_interval_ms: 2000

  # ─── External perception stream via MQTT (optional) ───────────────────────
  # Payload contract expected on topic:
  # {
  #   "schema": "ori.perception.v1",
  #   "sensor_type": "ppe_hardhat_violation_score",
  #   "value": 0.84,
  #   "confidence": 0.91,
  #   "timestamp_ms": 1710000000123,
  #   "metadata": {
  #     "zone_id": "line-3",
  #     "camera_id": "cam-04",
  #     "subject_id": "worker-17"
  #   }
  # }
  # - id: ppe-hardhat-cam-04
  #   type: ppe_hardhat_violation_score
  #   protocol: mqtt_perception
  #   broker_host: "192.168.1.20"
  #   topic: "ori/perception/site-b/cam-04"
  #   port: 1883
  #   poll_interval_ms: 1000
  #
  # - id: ppe-vest-cam-04
  #   type: ppe_vest_violation_score
  #   protocol: mqtt_perception
  #   broker_host: "192.168.1.20"
  #   topic: "ori/perception/site-b/cam-04"
  #   port: 1883
  #   poll_interval_ms: 1000


skills:
  - name: energy-anomaly-detector
    version: '0.2.1'
    config:
      energy_cost_naira: 225         # N/kWh — update with current rate
      owner_name: "Ikeja Office"
      requires_approval_for_soft_actions: false
      approval_timeout_seconds: 300
      safe_default_action: log_to_dashboard
      # secondary_contact_number: "${SECONDARY_WHATSAPP}"


reasoning:
  default_tier: local                # rule | local | gateway | cloud
  local_model: qwen2.5-0.5b-instruct-q4_k_m  # basename or full .gguf filename/path
  model_path: /home/pi/models/       # directory containing local GGUF models
  offline_fallback: rule             # tier to use when network unavailable
  escalation_threshold: 0.70        # escalate if confidence below this
  capability_posture:
    enabled: true
    probe_interval_seconds: 30      # must be <=30; posture refresh cadence
    gateway_heartbeat_ttl_seconds: 30
    internet_probe_host: one.one.one.one
    internet_probe_port: 53
    internet_probe_timeout_ms: 1000
  energy_aware_reasoning:
    enabled: true
    throttle_threshold_percent: 20
    critical_threshold_percent: 10
    battery_sensor_id: ""            # set to a real battery sensor id (for example victron-battery or inverter-battery-soc)
    alert_on_throttle: true
  causal_memory:
    rejection_expiry_days: 30      # 0 = never expire


gateway:
  enabled: false                     # set true when gateway Pi is on the LAN
  broker_url: mqtt://192.168.1.10:1883

device_policy:
  enabled: false
  url: "https://api.ori.cloud/v1/device-policy" # ori-cloud endpoint for signed DevicePolicy
  auth_token: "${ORI_DEVICE_POLICY_TOKEN}"      # device auth bearer token
  public_key_b64: "${ORI_CLOUD_PUBKEY_B64}"     # ori-cloud Ed25519 public key (base64)
  request_timeout_ms: 3000
  max_clock_skew_s: 300
  refresh_enabled: false                         # background refresh loop
  refresh_interval_s: 21600                      # 6h; minimum allowed is 60s

health_socket:
  enabled: true
  path: /run/ori/health.sock                     # local read-only runtime health RPC
  mode: 0o660                                    # unix socket permission bits

actions:
  # For Nigeria: use sms as primary (Africa's Talking — no approval required)
  # For UK/EU:   use whatsapp as primary
  primary_alert_channel: sms
  operator_contact: "${OWNER_PHONE_NUMBER}"          # Unified: WHO to contact for Tier-C Approvals
  secondary_contact: ""                              # Optional escalation contact

  whatsapp:
    enabled: true
    TWILIO_ACCOUNT_SID: "${TWILIO_ACCOUNT_SID}"
    TWILIO_AUTH_TOKEN: "${TWILIO_AUTH_TOKEN}"
    TWILIO_WHATSAPP_FROM: "${TWILIO_WHATSAPP_FROM}"

  sms:
    enabled: true                    # SMS transport enabled
    transport: hybrid                # ip | gsm | hybrid
    hybrid_order: gsm_first          # ip_first | gsm_first (used only when transport=hybrid)
    AT_API_KEY: "${AT_API_KEY}"
    AT_USERNAME: "${AT_USERNAME}"
    AT_SENDER_ID: "${AT_SENDER_ID}"
    gsm:
      enabled: false                 # set true to enable direct modem SMS transport
      port: "/dev/ttyUSB0"
      baud: 115200
      sim_pin: ""
      timeout_s: 5.0
      command_timeout_s: 3.0
      write_timeout_s: 3.0
    incoming_webhook:
      enabled: false                 # set true when exposing a public webhook endpoint
      host: "0.0.0.0"
      port: 8080
      path: "/webhooks/sms/africastalking"
      token: "${ORI_SMS_WEBHOOK_TOKEN}"  # required; shared secret checked on inbound requests

  local_console:
    enabled: false                   # Tier C local fallback when SMS/WhatsApp are unavailable
    poll_interval_ms: 1000
    approval_channel_id: "local_console"

  offline_tokens:
    enabled: false                   # Tier C offline cryptographic approval tokens
    public_key_b64: "${ORI_OFFLINE_TOKEN_PUBKEY_B64}"
    max_clock_skew_s: 300

  relay:
    enabled: false                   # CHANGE TO true ONLY WHEN RELAY IS WIRED
    gpio_pin: 26                     # BCM pin number connected to relay IN
    active_high: true

  # CoAP command transport (optional; constrained-device actuation path)
  # CoAP commands are executed through `coap_command` actions in skills.
  coap:
    enabled: false
    timeout_s: 2.0
    retries: 1
    allowed_hosts: ["192.168.1.70"]  # required when enabled
    commands:
      open_bypass_valve:
        uri: "coap://192.168.1.70/actuators/bypass"
        method: POST
        payload: '{"state":"open"}'


hal:
  circuit_breaker:
    failure_threshold: 5             # consecutive failures before circuit opens
    recovery_timeout_s: 300          # seconds to wait before probing (HALF_OPEN)
    success_threshold: 2             # consecutive successes in HALF_OPEN to close
  external_watchdog:
    enabled: false                   # optional GPIO heartbeat for external watchdog ICs
    gpio_pin: 17                     # BCM pin connected to watchdog DONE/WDI pin
    ping_interval_s: 30              # heartbeat interval in seconds
  status_signaling:
    enabled: false                   # LED/buzzer runtime state signaling
    power_led_pin: 17                # BCM pin: power source indicator
    relay_led_pin: 27                # BCM pin: relay state indicator
    network_led_pin: 22              # BCM pin: network/cellular indicator
    health_led_pin: 23               # BCM pin: runtime health indicator
    buzzer_pin: 24                   # BCM pin: audible alert indicator
    tick_ms: 100                     # pattern update interval in milliseconds


logging:
  level: INFO                        # DEBUG | INFO | WARNING | ERROR
  file: ori.log
  max_bytes: 10485760               # 10MB
  backup_count: 3
  log_action_decisions: true        # log every action dispatcher decision
  log_approval_workflow: true       # log Tier C approval requests and responses
