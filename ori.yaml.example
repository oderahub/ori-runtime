# ori.yaml.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ori.yaml and edit for your device.
# ori.yaml is gitignored — never commit it.
#
# ACTION TIER REFERENCE:
#   Tier A  INFORMATIONAL   — Always autonomous. Alerts, logs, reports.
#   Tier B  SOFT PHYSICAL   — Autonomous by default. Power switching, valves.
#   Tier C  HARD PHYSICAL   — Approval workflow required. Breakers, shutdowns.
#   Tier D  SAFETY-CRITICAL — Always autonomous. Cannot be overridden.
# ─────────────────────────────────────────────────────────────────────────────

device:
  id: energy-monitor-ikeja-01        # unique, no spaces, no special chars
  name: Ikeja Office Energy Monitor
  location: Lagos, Nigeria
  deployment_type: pi                # pi | phone | server
  rated_capacity_amps: 10.0          # used for Tier D threshold calculations
                                     # set this to the actual rated amperage
                                     # of your main circuit
  timezone: Africa/Lagos             # IANA timezone for Tier C approval messages
                                     # operators see local time, not UTC
                                     # e.g. Africa/Lagos, Europe/London, America/New_York

sensors:
  # ─── Current clamp on ADS1115 ADC via I2C ───────────────────────────────
  # SCT-013-030 clips around the main load cable in the distribution board
  # Non-invasive — no wiring changes required
  - id: load-current
    type: current_clamp
    protocol: i2c
    address: 0x48                    # ADS1115 default I2C address
    channel: 0                       # ADS1115 channel A0
    poll_interval_ms: 1000
    calibration:
      sensitivity: 0.1              # SCT-013-030: 1A per 10mV output

  # ─── Grid voltage sensor on ADS1115 channel 1 ───────────────────────────
  - id: grid-voltage
    type: voltage
    protocol: i2c
    address: 0x48
    channel: 1
    poll_interval_ms: 2000

  # ─── Inverter battery state ──────────────────────────────────────────────
  # Comment out if your inverter does not expose a serial interface
  - id: inverter-battery
    type: battery_state
    protocol: serial
    port: /dev/ttyUSB0
    baud_rate: 9600
    poll_interval_ms: 5000

  # ─── Growatt/Deye inverter via SolarmanV5 (optional) ─────────────────────
  # Uncomment for installations with a Growatt or Deye WiFi/LAN dongle
  # - id: inverter-solar-power
  #   type: growatt_pv_power
  #   protocol: growatt
  #   host: "192.168.1.XXX"
  #   serial: "XXXXXXXXXX"
  #   port: 8899
  #   poll_interval_ms: 5000

  # ─── Victron inverter via VenusOS MQTT (optional) ──────────────────────────
  # - id: victron-battery
  #   type: victron_battery_soc
  #   protocol: victron
  #   broker_host: "192.168.1.50"
  #   portal_id: "YOUR_PORTAL_ID"
  #   port: 1883
  #   # Optional broker auth/TLS (works with Mosquitto and other MQTT brokers)
  #   mqtt:
  #     username: "mqtt-user"
  #     password: "${MQTT_PASSWORD}"
  #     client_id: "ori-victron-01"
  #     keepalive: 90
  #     tls:
  #       enabled: false
  #       insecure: false
  #       # ca_certfile: "/etc/ssl/certs/ca-certificates.crt"
  #       # certfile: "/path/to/client.crt"
  #       # keyfile: "/path/to/client.key"
  #   poll_interval_ms: 5000

  # ─── OPC-UA industrial PLC sensor (optional) ───────────────────────────────
  # - id: plc-temperature
  #   type: temperature
  #   protocol: opcua
  #   url: "opc.tcp://192.168.1.100:4840"
  #   node_id: "ns=2;i=1002"
  #   poll_interval_ms: 1000

  # ─── PC/Mac system health (PC-Ori) ──────────────────────────────────────
  # Uncomment to monitor the host machine — no hardware required
  # - id: system-cpu
  #   type: cpu_percent
  #   protocol: psutil
  #   poll_interval_ms: 5000
  #
  # - id: system-memory
  #   type: memory_percent
  #   protocol: psutil
  #   poll_interval_ms: 10000
  #
  # - id: system-temp
  #   type: cpu_temp
  #   protocol: psutil
  #   poll_interval_ms: 10000

  # ─── Phone Gateway USB meter (Termux path) ───────────────────────────────
  # - id: mains-power
  #   type: usb_power
  #   protocol: usb_serial
  #   device_path: /dev/ttyUSB0
  #   baud_rate: 9600
  #   poll_interval_ms: 2000

  # ─── Virtual sensor: weather API (optional) ───────────────────────────────
  # - id: outdoor-temperature
  #   type: temperature
  #   protocol: http
  #   url: "http://api.openweathermap.org/data/2.5/weather?q=Lagos&appid=YOUR_KEY"
  #   json_path: "main.temp"
  #   unit: kelvin
  #   poll_interval_ms: 300000


skills:
  - name: energy-anomaly-detector
    version: '0.2.1'
    config:
      energy_cost_naira: 225         # N/kWh — update with current rate
      owner_name: "Ikeja Office"
      requires_approval_for_soft_actions: false
      approval_timeout_seconds: 300
      safe_default_action: log_to_dashboard
      # secondary_contact_number: "${SECONDARY_WHATSAPP}"


reasoning:
  default_tier: local                # rule | local | gateway | cloud
  local_model: qwen2.5-0.5b-instruct-q4_k_m
  model_path: /home/pi/models/       # directory where .gguf model files live
  offline_fallback: rule             # tier to use when network unavailable
  escalation_threshold: 0.70        # escalate if confidence below this
  energy_aware_reasoning:
    enabled: true
    throttle_threshold_percent: 20
    critical_threshold_percent: 10
    battery_sensor_id: inverter-battery
    alert_on_throttle: true
  causal_memory:
    rejection_expiry_days: 30      # 0 = never expire


gateway:
  enabled: false                     # set true when gateway Pi is on the LAN
  broker_url: mqtt://192.168.1.10:1883


actions:
  # For Nigeria: use sms as primary (Africa's Talking — no approval required)
  # For UK/EU:   use whatsapp as primary
  primary_alert_channel: sms
  operator_contact: "${OWNER_PHONE_NUMBER}"          # Unified: WHO to contact for Tier-C Approvals
  secondary_contact: ""                              # Optional escalation contact

  whatsapp:
    enabled: true
    TWILIO_ACCOUNT_SID: "${TWILIO_ACCOUNT_SID}"
    TWILIO_AUTH_TOKEN: "${TWILIO_AUTH_TOKEN}"
    TWILIO_WHATSAPP_FROM: "${TWILIO_WHATSAPP_FROM}"

  sms:
    enabled: true                    # Africa's Talking — primary for Nigeria
    AT_API_KEY: "${AT_API_KEY}"
    AT_USERNAME: "${AT_USERNAME}"
    incoming_webhook:
      enabled: false                 # set true when exposing a public webhook endpoint
      host: "0.0.0.0"
      port: 8080
      path: "/webhooks/sms/africastalking"
      token: "${ORI_SMS_WEBHOOK_TOKEN}"  # required; shared secret checked on inbound requests

  relay:
    enabled: false                   # CHANGE TO true ONLY WHEN RELAY IS WIRED
    gpio_pin: 26                     # BCM pin number connected to relay IN
    active_high: true


hal:
  circuit_breaker:
    failure_threshold: 5             # consecutive failures before circuit opens
    recovery_timeout_s: 300          # seconds to wait before probing (HALF_OPEN)
    success_threshold: 2             # consecutive successes in HALF_OPEN to close


logging:
  level: INFO                        # DEBUG | INFO | WARNING | ERROR
  file: ori.log
  max_bytes: 10485760               # 10MB
  backup_count: 3
  log_action_decisions: true        # log every action dispatcher decision
  log_approval_workflow: true       # log Tier C approval requests and responses
